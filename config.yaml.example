# HTTP server for the shim itself.
shim:
  # Address where the shim listens for incoming requests.
  addr: ":8080"
  # Maximum time allowed to read an HTTP request from the client.
  read_timeout: 15s
  # Maximum time allowed to write an HTTP response to the client.
  # SSE responses lift the write deadline while a live stream is active.
  write_timeout: 90s
  # Idle timeout for keep-alive connections.
  idle_timeout: 60s
  auth:
    # disabled: no shim-owned ingress auth
    # static_bearer: require one of the configured bearer tokens on non-health routes
    mode: disabled
    # Shared ingress tokens accepted by the shim itself.
    # These tokens are not forwarded upstream.
    bearer_tokens: []
  rate_limit:
    # Enables a shim-owned in-memory per-client request limiter.
    enabled: false
    # Sustained request budget per minute.
    requests_per_minute: 120
    # Immediate burst budget before refill.
    burst: 60
  metrics:
    # Enables a shim-owned Prometheus-text metrics endpoint.
    enabled: true
    path: /metrics
  limits:
    # Maximum JSON request body for non-multipart routes.
    json_body_bytes: 1MiB
    # Maximum uploaded file size for /v1/files and /v1/containers/*/files.
    retrieval_file_upload_bytes: 64MiB
    # Maximum sanitized non-stream /v1/chat/completions body captured for
    # optional local shadow storage. Responses above this size are still
    # proxied to the client but are not persisted locally.
    chat_completions_shadow_store_bytes: 64MiB
    # Maximum time spent on best-effort local Chat Completions shadow-store
    # persistence after the upstream response has completed. This internal
    # storage write is detached from client disconnect cancellation.
    chat_completions_shadow_store_timeout: 5s
    # Maximum non-stream /v1/responses upstream body buffered for shim-owned
    # normalization, retry decisions, and optional local shadow storage.
    # Responses above this size are proxied unchanged and are not persisted locally.
    responses_proxy_buffer_bytes: 64MiB
    # Maximum number of stored response ancestors reconstructed for shim-owned
    # previous_response_id local context and legacy input_items fallback.
    # This is an internal storage/context cap, not an OpenAI request parameter.
    responses_stored_lineage_max_items: 128
    # Maximum tool-output text injected into shim-local final Responses generation
    # after client-executed tool results. This is an internal prompt cap, not an
    # OpenAI request parameter.
    responses_local_tool_output_summary_bytes: 64KiB
    # Maximum grammar definition size accepted by shim-local constrained custom tools.
    custom_tool_grammar_definition_bytes: 16KiB
    # Maximum compiled regex/pattern size accepted after regex or Lark expansion.
    custom_tool_compiled_pattern_bytes: 32KiB
    # Maximum concurrent retrieval searches across raw vector search and local file_search.
    retrieval_max_concurrent_searches: 8
    # Maximum number of rewritten search queries per retrieval request.
    retrieval_max_search_queries: 4
    # Maximum number of grounding chunks injected into local file_search generation context.
    retrieval_max_grounding_chunks: 20
    # Maximum concurrent shim-local code_interpreter executions.
    code_interpreter_max_concurrent_runs: 2

# Storage backend selector. Only sqlite is implemented today; this key exists
# so future Postgres/pgvector storage can be introduced without changing the
# OpenAI-facing route contract.
storage:
  backend: sqlite

# Local SQLite state storage owned by the shim.
sqlite:
  # Path to the SQLite file that stores responses and conversations.
  path: ./.data/shim.db
  maintenance:
    # Sweep interval for expired local retrieval resources with `expires_at`.
    cleanup_interval: 15m

# Upstream OpenAI-compatible backend.
llama:
  # Base URL of the upstream server.
  # Local generation calls its /v1/chat/completions endpoint.
  base_url: http://127.0.0.1:8081
  # Timeout for ordinary upstream requests.
  # Streaming uses a dedicated client without a shared request timeout.
  timeout: 60s
  # Internal admission control for expensive upstream create/generate paths.
  # 0 disables shim-side concurrency smoothing.
  max_concurrent_requests: 4
  # Optional extra wait budget for the internal admission queue.
  # 0 means wait only as long as the request context allows.
  max_queue_wait: 0s
  http:
    # Shared upstream connection-pool tuning for both request and stream clients.
    max_idle_conns: 32
    max_idle_conns_per_host: 16
    max_conns_per_host: 8
    idle_conn_timeout: 90s
    dial_timeout: 10s
    keep_alive: 30s
    tls_handshake_timeout: 10s
    expect_continue_timeout: 1s

# Shimctl-only probe settings living in the same shared config file.
probe:
  count: 3
  request_timeout: 8s
  bearer_token: ""
  model: ""

# Shim logging.
log:
  # Log level: debug, info, warn, error.
  level: info
  # When set, logs are written to both stdout and this file.
  file_path: ./.data/shim.log

# Local retrieval engine.
retrieval:
  index:
    # lexical: default deterministic text matching over local chunks
    # sqlite_vec: exact dense cosine search over persisted embeddings in SQLite
    backend: lexical
  embedder:
    # disabled: default; only lexical retrieval works
    # openai_compatible: any local/remote /v1/embeddings endpoint
    # embedanything: EmbedAnything Actix server using the same OpenAI-compatible surface
    backend: disabled
    # Base URL of the embeddings server. For EmbedAnything this is typically
    # http://127.0.0.1:8080
    base_url: ""
    # Embedding model identifier understood by the embedder server.
    model: ""

# Shim-owned policy for Chat Completions storage when requests omit `store`.
chat_completions:
  # true: shadow-store omitted-store chat completions locally, matching the
  # current OpenAI default for new accounts
  # false: only explicit `store: true` is shadow-stored locally
  default_store_when_omitted: true
  upstream_compatibility:
    # Model-specific request-shape compatibility for upstream
    # /v1/chat/completions calls. These rules affect both direct
    # /v1/chat/completions proxying and shim-generated Chat requests used by
    # local Responses helpers. They do not change the public OpenAI-shaped
    # request accepted by the shim.
    models: []
    # Example for DeepSeek-compatible gateways:
    # models:
    #   - model: deepseek-*
    #     # DeepSeek Chat accepts system/user/assistant/tool roles, while
    #     # OpenAI Chat examples can send role=developer.
    #     remap_developer_role: true
    #     # passthrough: do not add a thinking field
    #     # disabled: add thinking: {type: disabled} when the caller omitted it
    #     default_thinking: disabled
    #     # passthrough: forward response_format unchanged
    #     # json_object_instruction: downgrade Chat response_format=json_schema
    #     # to json_object and prepend the schema as a system instruction
    #     json_schema_mode: json_object_instruction
    # Example for Kimi/Moonshot-compatible gateways:
    # models:
    #   - model: Kimi-*
    #     # Some Kimi/LiteLLM model groups reject a Chat Completions `thinking`
    #     # request field. Keep passthrough unless the upstream explicitly
    #     # supports the Kimi/Moonshot thinking body shape.
    #     default_thinking: passthrough
    #     # Some Kimi/LiteLLM deployments reject OpenAI Chat
    #     # response_format=json_schema in Codex local tool loops. Downgrade
    #     # to JSON mode and prepend the schema instruction before upstream.
    #     json_schema_mode: json_object_instruction
    #     # Kimi's own CLI defaults agent Chat calls to a large generation
    #     # budget. This value is applied only when the client omitted both
    #     # max_tokens and max_completion_tokens.
    #     default_max_tokens: 32000
    #     # Kimi rejects some JSON Schema-valid function parameter properties
    #     # that omit type, for example enum-only nested fields. This fills in
    #     # compatible type values before forwarding tools upstream.
    #     ensure_tool_parameter_property_types: true
    #     # Moonshot/Kimi rejects some schema forms that other OpenAI-like
    #     # providers accept: sibling keywords next to `$ref`, and tuple-style
    #     # array `items`. Keep this model-scoped.
    #     sanitize_moonshot_tool_schema: true
    #     # Kimi's coding compatibility layer accepts omitted assistant
    #     # content on tool-call messages more reliably than empty content.
    #     omit_empty_assistant_tool_content: true
    #     # Retry one shim-local tool-loop Chat call when a Kimi/LiteLLM
    #     # upstream rejects generated tool arguments as empty/invalid JSON.
    #     # This is a model-scoped compatibility workaround, not OpenAI API behavior.
    #     retry_invalid_tool_arguments: true
    #     # If the retry is exhausted after local tool outputs already exist,
    #     # ask upstream for final plain text without tools instead of
    #     # surfacing a 502. Supported values: none, final_text.
    #     invalid_tool_arguments_fallback: final_text
    # Example for Qwen/DashScope-compatible gateways:
    # models:
    #   - model: Qwen*
    #     # Qwen Code exposes thinking through OpenAI-compatible extra_body
    #     # options such as enable_thinking. Do not inject a generic thinking
    #     # field unless the exact upstream accepts it.
    #     default_thinking: passthrough
    #     # Some Qwen/LiteLLM gateways reject Chat response_format=json_schema
    #     # when the schema is provided by shim-local constrained helpers.
    #     # Downgrade to JSON mode and prepend the schema instruction upstream.
    #     json_schema_mode: json_object_instruction

# Settings for the OpenAI Responses-compatible layer.
responses:
  # How /v1/responses is routed.
  # prefer_local: default; handle locally whenever the shim supports the request.
  # prefer_upstream: preserve the legacy proxy-first behavior for standalone requests.
  # local_only: never call upstream /v1/responses; reject unsupported features instead.
  mode: prefer_local
  websocket:
    # Enables V3 local-subset Responses WebSocket mode at GET /v1/responses.
    # Keep this enabled when using Codex providers configured with
    # supports_websockets=true. HTTP POST /v1/responses and SSE stream=true
    # remain available either way.
    enabled: true
  web_search:
    # disabled: no shim-local web_search runtime
    # searxng: query a local or remote SearXNG-compatible backend
    backend: disabled
    # Base URL of the web search backend, for example http://127.0.0.1:8084
    base_url: ""
    # Timeout per search/open_page request to the web search backend.
    timeout: 10s
    # Maximum results requested from the web search backend per rewritten query.
    max_results: 10
  image_generation:
    # disabled: no shim-local image_generation runtime
    # responses: delegate one image_generation tool to a separate
    # OpenAI-compatible /v1/responses image backend
    backend: disabled
    # Base URL of the image backend, for example http://127.0.0.1:8085
    base_url: ""
    # Timeout per local image generation request to the image backend.
    timeout: 60s
  compaction:
    # heuristic: deterministic fallback compactor
    # model_assisted_text: call a fast OpenAI-compatible /v1/chat/completions
    # backend to produce richer shim-owned opaque compaction state
    backend: heuristic
    # Base URL of the compaction backend. When omitted with model_assisted_text,
    # llama.base_url is reused.
    base_url: ""
    # Fast local model used only for internal compaction when model_assisted_text
    # is enabled.
    model: ""
    # Timeout per internal compaction model request.
    timeout: 10s
    # Output budget sent to the compaction model.
    max_output_tokens: 1000
    # Number of recent prior items retained for model-assisted compaction.
    # Standalone compact responses return these as visible canonical-window
    # items; automatic compaction carries them inside shim-owned opaque state.
    retained_items: 8
    # Maximum prior-context characters rendered into the compaction prompt.
    max_input_chars: 32000
  computer:
    # disabled: no shim-local computer runtime
    # chat_completions: use the configured upstream /v1/chat/completions
    # backend as a local computer planner for screenshot-first external loops
    backend: disabled
  custom_tools:
    # How custom tools are transported to the upstream.
    # auto: recommended default; use shim-local constrained runtime for
    # supported grammar-constrained tools when Responses is handled locally,
    # bridge plain-text custom tools when possible, and fall back to passthrough
    # for standalone proxy requests.
    # bridge: always rewrite custom tools into a compatible upstream format.
    # passthrough: always forward them unchanged.
    mode: auto
  constrained_decoding:
    # shim_validate_repair: default; use shim-local prompts plus final local
    # validation/repair for constrained custom tools.
    # vllm: use vLLM /v1/chat/completions structured_outputs.regex for
    # grammar.syntax=regex and structured_outputs.grammar for the shim-supported
    # grammar.syntax=lark subset when the local constrained runtime is selected.
    backend: shim_validate_repair
  upstream_tool_compatibility:
    # Model-specific upstream compatibility filters. Exact names and `*`
    # wildcards are supported. This does not change the OpenAI Responses
    # contract: passive declarations of disabled tools are removed before
    # proxying to that upstream model, while explicit tool_choice for a
    # disabled tool is rejected.
    models: []
    # Example for LiteLLM/Kimi backends that reject some official/OpenAI-SDK
    # Responses tool types. SDK NamespaceTool is sent on the wire as
    # type: namespace; namespace_tool is accepted here as a config alias.
    # models:
    #   - model: Kimi-*
    #     disabled_tools:
    #       - image_generation
    #       - namespace
  codex:
    # Enables Codex-compatible payload and response adaptations for /v1/responses.
    enable_compatibility: true
    # When true, Codex-like requests with tool_choice=auto are rewritten to
    # required before they are sent upstream.
    force_tool_choice_required: true
    # Model patterns where the required-tool rewrite is disabled. This is useful
    # for upstreams that can call tools but degrade on ordinary assistant
    # questions when every Codex turn is forced to call a tool.
    force_tool_choice_required_disabled_models: []
    # Example:
    # force_tool_choice_required_disabled_models:
    #   - Kimi-*
    upstream_input_compatibility:
      # Per-model upstream request shape overrides for Codex-compatible clients.
      # mode=auto keeps official structured Responses input and only falls back
      # to a stringified transcript after a known upstream validation error.
      # mode=stringify rewrites structured input to a plain text transcript
      # before the first upstream request. Use this for OpenAI-compatible
      # backends that reject structured Responses input after Codex tool output.
      # mode=structured disables that pre-stringify shortcut for the model.
      models: []
      # Example:
      # models:
      #   - model: Kimi-*
      #     mode: stringify
    model_metadata:
      # Optional Codex model catalog entries served only to Codex metadata
      # requests (`/v1/models?client_version=...` or `/api/codex/models`).
      # Ordinary OpenAI-compatible GET /v1/models stays proxied unchanged.
      models: []
      # Examples. Replace `models: []` with one list containing the entries
      # needed by your Codex upstreams.
      # models:
      #   - model: Kimi-K2.6
      #     display_name: Kimi K2.6
      #     description: OpenAI-compatible upstream routed through llama_shim.
      #     context_window: 262144
      #     max_context_window: 262144
      #     auto_compact_token_limit: 0
      #     effective_context_window_percent: 90
      #     default_reasoning_level: high
      #     supported_reasoning_levels: [low, medium, high]
      #     supports_reasoning_summaries: false
      #     default_reasoning_summary: none
      #     shell_type: shell_command
      #     apply_patch_tool_type: freeform
      #     web_search_tool_type: text
      #     supports_parallel_tool_calls: false
      #     support_verbosity: false
      #     default_verbosity: ""
      #     supports_image_detail_original: false
      #     supports_search_tool: false
      #     input_modalities: [text]
      #     visibility: list
      #     supported_in_api: true
      #     priority: 100
      #     additional_speed_tiers: []
      #     experimental_supported_tools: []
      #     availability_nux_message: ""
      #     truncation_policy:
      #       mode: bytes
      #       limit: 10000
      #     base_instructions: ""
      #   # DeepSeek upstream that has passed the external tester:
      #   - model: deepseek-v4-pro
      #     display_name: DeepSeek V4 Pro
      #     description: OpenAI-compatible DeepSeek upstream routed through llama_shim.
      #     context_window: 1000000
      #     max_context_window: 1000000
      #     auto_compact_token_limit: 0
      #     effective_context_window_percent: 90
      #     default_reasoning_level: high
      #     supported_reasoning_levels: [low, medium, high]
      #     supports_reasoning_summaries: false
      #     default_reasoning_summary: none
      #     shell_type: shell_command
      #     apply_patch_tool_type: freeform
      #     web_search_tool_type: text
      #     supports_parallel_tool_calls: false
      #     support_verbosity: false
      #     default_verbosity: ""
      #     supports_image_detail_original: false
      #     supports_search_tool: false
      #     input_modalities: [text]
      #     visibility: list
      #     supported_in_api: true
      #     priority: 110
      #     additional_speed_tiers: []
      #     experimental_supported_tools: []
      #     availability_nux_message: ""
      #     truncation_policy:
      #       mode: bytes
      #       limit: 10000
      #     base_instructions: ""
      #   # Tested Qwen3.6 gateway path:
      #   - model: Qwen3.6-35B-A3B
      #     display_name: Qwen3.6 35B A3B
      #     description: OpenAI-compatible Qwen3.6 upstream routed through llama_shim.
      #     # Conservative tested default. Raise only after the exact upstream
      #     # deployment proves a larger long-context setting end to end.
      #     context_window: 262144
      #     max_context_window: 262144
      #     auto_compact_token_limit: 0
      #     effective_context_window_percent: 90
      #     default_reasoning_level: high
      #     supported_reasoning_levels: [low, medium, high]
      #     supports_reasoning_summaries: false
      #     default_reasoning_summary: none
      #     shell_type: shell_command
      #     apply_patch_tool_type: freeform
      #     web_search_tool_type: text
      #     supports_parallel_tool_calls: false
      #     support_verbosity: false
      #     default_verbosity: ""
      #     supports_image_detail_original: false
      #     supports_search_tool: false
      #     input_modalities: [text]
      #     visibility: list
      #     supported_in_api: true
      #     priority: 105
      #     additional_speed_tiers: []
      #     experimental_supported_tools: []
      #     availability_nux_message: ""
      #     truncation_policy:
      #       mode: bytes
      #       limit: 10000
      #     base_instructions: ""
  code_interpreter:
    # disabled: reject shim-local code_interpreter execution
    # docker: hardened Docker-backed local execution and the only supported
    # local runtime boundary
    backend: disabled
    # Maximum execution time per local code_interpreter run.
    execution_timeout: 20s
    docker:
      # Docker binary used by the docker backend.
      binary: docker
      # Sandbox image used for local code_interpreter runs.
      image: python:3.12-slim
      memory_limit: 1g
      cpu_limit: "0.5"
      pids_limit: 64
    # disabled: reject remote input_file.file_url
    # allowlist: allow only configured hosts
    # unsafe_allow_http_https: allow any http(s) URL
    input_file_url_policy: disabled
    input_file_url_allow_hosts: []
    # Sweep interval for expired shim-managed code_interpreter containers.
    cleanup_interval: 1m
    limits:
      # Maximum number of generated artifacts persisted from one run.
      generated_files: 8
      # Maximum size of one generated artifact.
      generated_file_bytes: 2MiB
      # Maximum aggregate size of persisted generated artifacts from one run.
      generated_total_bytes: 8MiB
      # Maximum size fetched from one remote input_file.file_url.
      remote_input_file_bytes: 50MiB

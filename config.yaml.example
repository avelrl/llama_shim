# HTTP server for the shim itself.
shim:
  # Address where the shim listens for incoming requests.
  addr: ":8080"
  # Maximum time allowed to read an HTTP request from the client.
  read_timeout: 15s
  # Maximum time allowed to write an HTTP response to the client.
  # SSE responses lift the write deadline while a live stream is active.
  write_timeout: 90s
  # Idle timeout for keep-alive connections.
  idle_timeout: 60s
  auth:
    # disabled: no shim-owned ingress auth
    # static_bearer: require one of the configured bearer tokens on non-health routes
    mode: disabled
    # Shared ingress tokens accepted by the shim itself.
    # These tokens are not forwarded upstream.
    bearer_tokens: []
  rate_limit:
    # Enables a shim-owned in-memory per-client request limiter.
    enabled: false
    # Sustained request budget per minute.
    requests_per_minute: 120
    # Immediate burst budget before refill.
    burst: 60
  metrics:
    # Enables a shim-owned Prometheus-text metrics endpoint.
    enabled: true
    path: /metrics
  limits:
    # Maximum JSON request body for non-multipart routes.
    json_body_bytes: 1MiB
    # Maximum uploaded file size for /v1/files and /v1/containers/*/files.
    retrieval_file_upload_bytes: 64MiB
    # Maximum sanitized non-stream /v1/chat/completions body captured for
    # optional local shadow storage. Responses above this size are still
    # proxied to the client but are not persisted locally.
    chat_completions_shadow_store_bytes: 64MiB
    # Maximum non-stream /v1/responses upstream body buffered for shim-owned
    # normalization, retry decisions, and optional local shadow storage.
    # Responses above this size are proxied unchanged and are not persisted locally.
    responses_proxy_buffer_bytes: 64MiB
    # Maximum number of stored response ancestors reconstructed for shim-owned
    # previous_response_id local context and legacy input_items fallback.
    # This is an internal storage/context cap, not an OpenAI request parameter.
    responses_stored_lineage_max_items: 128
    # Maximum grammar definition size accepted by shim-local constrained custom tools.
    custom_tool_grammar_definition_bytes: 16KiB
    # Maximum compiled regex/pattern size accepted after regex or Lark expansion.
    custom_tool_compiled_pattern_bytes: 32KiB
    # Maximum concurrent retrieval searches across raw vector search and local file_search.
    retrieval_max_concurrent_searches: 8
    # Maximum number of rewritten search queries per retrieval request.
    retrieval_max_search_queries: 4
    # Maximum number of grounding chunks injected into local file_search generation context.
    retrieval_max_grounding_chunks: 20
    # Maximum concurrent shim-local code_interpreter executions.
    code_interpreter_max_concurrent_runs: 2

# Local state storage owned by the shim.
sqlite:
  # Path to the SQLite file that stores responses and conversations.
  path: ./.data/shim.db
  maintenance:
    # Sweep interval for expired local retrieval resources with `expires_at`.
    cleanup_interval: 15m

# Upstream OpenAI-compatible backend.
llama:
  # Base URL of the upstream server.
  # Local generation calls its /v1/chat/completions endpoint.
  base_url: http://127.0.0.1:8081
  # Timeout for ordinary upstream requests.
  # Streaming uses a dedicated client without a shared request timeout.
  timeout: 60s
  # Internal admission control for expensive upstream create/generate paths.
  # 0 disables shim-side concurrency smoothing.
  max_concurrent_requests: 4
  # Optional extra wait budget for the internal admission queue.
  # 0 means wait only as long as the request context allows.
  max_queue_wait: 0s
  http:
    # Shared upstream connection-pool tuning for both request and stream clients.
    max_idle_conns: 32
    max_idle_conns_per_host: 16
    max_conns_per_host: 8
    idle_conn_timeout: 90s
    dial_timeout: 10s
    keep_alive: 30s
    tls_handshake_timeout: 10s
    expect_continue_timeout: 1s

# Shimctl-only probe settings living in the same shared config file.
probe:
  count: 3
  request_timeout: 8s
  bearer_token: ""
  model: ""

# Shim logging.
log:
  # Log level: debug, info, warn, error.
  level: info
  # When set, logs are written to both stdout and this file.
  file_path: ./.data/shim.log

# Local retrieval engine.
retrieval:
  index:
    # lexical: default deterministic text matching over local chunks
    # sqlite_vec: exact dense cosine search over persisted embeddings in SQLite
    backend: lexical
  embedder:
    # disabled: default; only lexical retrieval works
    # openai_compatible: any local/remote /v1/embeddings endpoint
    # embedanything: EmbedAnything Actix server using the same OpenAI-compatible surface
    backend: disabled
    # Base URL of the embeddings server. For EmbedAnything this is typically
    # http://127.0.0.1:8080
    base_url: ""
    # Embedding model identifier understood by the embedder server.
    model: ""

# Shim-owned policy for Chat Completions storage when requests omit `store`.
chat_completions:
  # true: shadow-store omitted-store chat completions locally, matching the
  # current OpenAI default for new accounts
  # false: only explicit `store: true` is shadow-stored locally
  default_store_when_omitted: true

# Settings for the OpenAI Responses-compatible layer.
responses:
  # How /v1/responses is routed.
  # prefer_local: default; handle locally whenever the shim supports the request.
  # prefer_upstream: preserve the legacy proxy-first behavior for standalone requests.
  # local_only: never call upstream /v1/responses; reject unsupported features instead.
  mode: prefer_local
  websocket:
    # Enables V3 local-subset Responses WebSocket mode at GET /v1/responses.
    # Keep this enabled when using Codex providers configured with
    # supports_websockets=true. HTTP POST /v1/responses and SSE stream=true
    # remain available either way.
    enabled: true
  web_search:
    # disabled: no shim-local web_search runtime
    # searxng: query a local or remote SearXNG-compatible backend
    backend: disabled
    # Base URL of the web search backend, for example http://127.0.0.1:8084
    base_url: ""
    # Timeout per search/open_page request to the web search backend.
    timeout: 10s
    # Maximum results requested from the web search backend per rewritten query.
    max_results: 10
  image_generation:
    # disabled: no shim-local image_generation runtime
    # responses: delegate one image_generation tool to a separate
    # OpenAI-compatible /v1/responses image backend
    backend: disabled
    # Base URL of the image backend, for example http://127.0.0.1:8085
    base_url: ""
    # Timeout per local image generation request to the image backend.
    timeout: 60s
  compaction:
    # heuristic: deterministic fallback compactor
    # model_assisted_text: call a fast OpenAI-compatible /v1/chat/completions
    # backend to produce richer shim-owned opaque compaction state
    backend: heuristic
    # Base URL of the compaction backend. When omitted with model_assisted_text,
    # llama.base_url is reused.
    base_url: ""
    # Fast local model used only for internal compaction when model_assisted_text
    # is enabled.
    model: ""
    # Timeout per internal compaction model request.
    timeout: 10s
    # Output budget sent to the compaction model.
    max_output_tokens: 1000
    # Number of recent prior items retained for model-assisted compaction.
    # Standalone compact responses return these as visible canonical-window
    # items; automatic compaction carries them inside shim-owned opaque state.
    retained_items: 8
    # Maximum prior-context characters rendered into the compaction prompt.
    max_input_chars: 32000
  computer:
    # disabled: no shim-local computer runtime
    # chat_completions: use the configured upstream /v1/chat/completions
    # backend as a local computer planner for screenshot-first external loops
    backend: disabled
  custom_tools:
    # How custom tools are transported to the upstream.
    # auto: recommended default; bridge plain-text custom tools when possible
    # and fall back to passthrough for grammar-constrained tools.
    # bridge: always rewrite custom tools into a compatible upstream format.
    # passthrough: always forward them unchanged.
    mode: auto
  codex:
    # Enables Codex-compatible payload and response adaptations for /v1/responses.
    enable_compatibility: true
    # When true, Codex-like requests with tool_choice=auto are rewritten to
    # required before they are sent upstream.
    force_tool_choice_required: true
  code_interpreter:
    # disabled: reject shim-local code_interpreter execution
    # docker: hardened Docker-backed local execution and the only supported
    # local runtime boundary
    backend: disabled
    # Maximum execution time per local code_interpreter run.
    execution_timeout: 20s
    docker:
      # Docker binary used by the docker backend.
      binary: docker
      # Sandbox image used for local code_interpreter runs.
      image: python:3.12-slim
      memory_limit: 1g
      cpu_limit: "0.5"
      pids_limit: 64
    # disabled: reject remote input_file.file_url
    # allowlist: allow only configured hosts
    # unsafe_allow_http_https: allow any http(s) URL
    input_file_url_policy: disabled
    input_file_url_allow_hosts: []
    # Sweep interval for expired shim-managed code_interpreter containers.
    cleanup_interval: 1m
    limits:
      # Maximum number of generated artifacts persisted from one run.
      generated_files: 8
      # Maximum size of one generated artifact.
      generated_file_bytes: 2MiB
      # Maximum aggregate size of persisted generated artifacts from one run.
      generated_total_bytes: 8MiB
      # Maximum size fetched from one remote input_file.file_url.
      remote_input_file_bytes: 50MiB

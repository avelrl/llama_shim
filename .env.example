# Repo-local convenience overrides. The shim auto-loads `.env` first and then
# lets real process environment variables win.

# Upstream OpenAI-compatible backend used by the shim.
LLAMA_BASE_URL=http://127.0.0.1:8081

# Common local paths and bind address.
SQLITE_PATH=./.data/shim.db
LOG_FILE_PATH=./.data/shim.log
SHIM_ADDR=:8080

# Optional shimctl probe overrides read from the same `.env`.
SHIMCTL_PROBE_BEARER_TOKEN=
SHIMCTL_PROBE_MODEL=
